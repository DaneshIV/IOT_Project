import RPi.GPIO as GPIO
import time
import warnings
from pymongo import MongoClient

warnings.filterwarnings('ignore')

MongoURI = "mongodb+srv://maiSakura:daneshmuthu@iotadmin.qhxngyt.mongodb.net/?retryWrites=true&w=majority&appName=iotadmin"
client = MongoClient(MongoURI, serverSelectionTimeoutMS=5000)
db_collection = client.PowerPlantDB.StatusCollection

GPIO.setmode(GPIO.BCM)
GreenLEDPin = 20
RedLEDPin = 21

GPIO.setup(GreenLEDPin, GPIO.OUT)
GPIO.setup(RedLEDPin, GPIO.OUT)

print("Emergency Board Active. Listening to cloud database...")
previous_status = None

try:
    while True:
        status_doc = db_collection.find_one()
        alarm_status = status_doc.get('alarm', 'False') if status_doc else 'False'

        if alarm_status != previous_status:
            if alarm_status == 'True':
                print("\n🔴 DATABASE TRIGGER: Powering Red LED (BCM 21)")
                GPIO.output(GreenLEDPin, False)
                GPIO.output(RedLEDPin, True)
            else:
                print("\n🟢 DATABASE TRIGGER: Powering Green LED (BCM 20)")
                GPIO.output(GreenLEDPin, True)
                GPIO.output(RedLEDPin, False)

            previous_status = alarm_status

        time.sleep(1)

except KeyboardInterrupt:
    print("\nShutting down Emergency Board...")
    GPIO.output(GreenLEDPin, False)
    GPIO.output(RedLEDPin, False)
    GPIO.cleanup()
