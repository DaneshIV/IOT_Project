import RPi.GPIO as GPIO
import time
import warnings
from pymongo import MongoClient

warnings.filterwarnings('ignore')

MongoURI = "mongodb+srv://maiSakura:daneshmuthu@iotadmin.qhxngyt.mongodb.net/?retryWrites=true&w=majority&appName=iotadmin"
client = MongoClient(MongoURI, serverSelectionTimeoutMS=5000)
db_collection = client.PowerPlantDB.StatusCollection

GPIO.setmode(GPIO.BCM)
buttonPin = 21
GPIO.setup(buttonPin, GPIO.IN)

print("Control Board Active. Press the button to trigger emergency...")
buttonState = previousIterationButtonState = GPIO.input(buttonPin)

try:
    while True:
        buttonState = GPIO.input(buttonPin)

        if buttonState != previousIterationButtonState:
            alarmValue = True if buttonState == 1 else False

            if alarmValue == True:
                print("\n🚨 EMERGENCY INITIATED: Sending 'True' to MongoDB...")
                db_collection.replace_one({'alarm': 'False'}, {'alarm': 'True'}, upsert=True)
            else:
                print("\n✅ SYSTEM NORMAL: Sending 'False' to MongoDB...")
                db_collection.replace_one({'alarm': 'True'}, {'alarm': 'False'}, upsert=True)

            previousIterationButtonState = buttonState

        time.sleep(0.1)

except KeyboardInterrupt:
    print("\nShutting down Control Board. Cleaning up GPIO...")
    GPIO.cleanup()
